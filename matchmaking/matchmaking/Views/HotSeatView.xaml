<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="matchmaking.Views.HotSeatView"
    x:Name="HotSeatViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="40" Spacing="24">

                <TextBlock Text="Hot Seat" FontSize="32" FontWeight="Bold"/>

                <TextBlock
                    Text="No one is in the Hot Seat today."
                    Visibility="{x:Bind VisInverse(ViewModel.HasHotSeatProfile), Mode=OneWay}"
                    FontSize="20"
                    Foreground="Gray"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                <Grid
                    Visibility="{x:Bind Vis(ViewModel.HasHotSeatProfile), Mode=OneWay}"
                    ColumnSpacing="24"
                    CornerRadius="12"
                    Background="#FF5A5F"
                    BorderBrush="#FF5A5F"
                    BorderThickness="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" CornerRadius="12,0,0,12" Background="Black">
                        <Image
                            Source="{x:Bind ViewModel.CurrentPhoto, Mode=OneWay, TargetNullValue='ms-appx:///Assets/placeholder.png'}"
                            Stretch="UniformToFill"
                            Height="400"/>
                        <Button
                            Click="PreviousPhoto_Click"
                            Content="&#xE76B;"
                            FontFamily="Segoe MDL2 Assets"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="#AA000000"
                            Foreground="White"
                            Margin="10"
                            Height="50" Width="50"
                            CornerRadius="25"/>
                        <Button
                            Click="NextPhoto_Click"
                            Content="&#xE76C;"
                            FontFamily="Segoe MDL2 Assets"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="#AA000000"
                            Foreground="White"
                            Margin="10"
                            Height="50" Width="50"
                            CornerRadius="25"/>
                    </Grid>

                    <ScrollViewer Grid.Column="1" Padding="30">
                        <StackPanel Spacing="15">
                            <TextBlock
                                Text="{x:Bind ViewModel.HotSeatProfile.Name, Mode=OneWay}"
                                FontSize="36"
                                FontWeight="Bold"
                                Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <TextBlock
                                    Text="{x:Bind ViewModel.HotSeatProfile.Age, Mode=OneWay}"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Foreground="White"/>
                                <TextBlock
                                    Text="{x:Bind ViewModel.HotSeatProfile.Gender, Mode=OneWay}"
                                    FontSize="20"
                                    Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE139;" Foreground="White" FontSize="18"/>
                                <TextBlock
                                    Text="{x:Bind ViewModel.HotSeatProfile.Location, Mode=OneWay}"
                                    FontSize="18"
                                    Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE12B;" Foreground="White" FontSize="18"/>
                                <TextBlock
                                    Text="{x:Bind ViewModel.HotSeatProfile.Nationality, Mode=OneWay}"
                                    FontSize="18"
                                    Foreground="White"/>
                            </StackPanel>

                            <MenuFlyoutSeparator Margin="0,10,0,10" Background="White" Opacity="0.5"/>

                            <TextBlock Text="Description" FontWeight="SemiBold" FontSize="20" Foreground="White"/>
                            <TextBlock
                                Text="{x:Bind ViewModel.HotSeatProfile.Bio, Mode=OneWay}"
                                TextWrapping="Wrap"
                                FontSize="16"
                                Foreground="White"/>

                            <MenuFlyoutSeparator Margin="0,10,0,10" Background="White" Opacity="0.5"/>

                            <TextBlock Text="Interests" FontWeight="SemiBold" FontSize="20" Foreground="White"/>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.HotSeatProfile.Interests, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border CornerRadius="6" Padding="12,8" BorderThickness="2" BorderBrush="White" Background="Transparent">
                                            <TextBlock Text="{Binding}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid
                    Visibility="{x:Bind Vis(ViewModel.ShowInteractionButtons), Mode=OneWay}"
                    Margin="0,20,0,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="40">
                        <Button
                            Click="SuperLikeHotSeat_Click"
                            Width="80" Height="80"
                            CornerRadius="40"
                            Background="Transparent"
                            BorderBrush="#00A4FF"
                            BorderThickness="4">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE735;" Foreground="#00A4FF" FontSize="44"/>
                        </Button>
                        <Button
                            Click="LikeHotSeat_Click"
                            Width="80" Height="80"
                            CornerRadius="40"
                            Background="Transparent"
                            BorderBrush="#1CEE91"
                            BorderThickness="4">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB51;" Foreground="#1CEE91" FontSize="44"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <MenuFlyoutSeparator Margin="0,10,0,10"/>

                <TextBlock Text="Today's Auction" FontSize="24" FontWeight="Bold"/>

                <TextBlock
                    Text="No one has bid yet."
                    Visibility="{x:Bind Vis(ViewModel.HasNoBid), Mode=OneWay}"
                    Foreground="Gray"
                    FontSize="16"/>

                <StackPanel
                    Visibility="{x:Bind Vis(ViewModel.HasBid), Mode=OneWay}"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock Text="Current highest bid:" FontSize="16"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.HighestBid, Mode=OneWay}"
                        FontSize="16"
                        FontWeight="SemiBold"/>
                    <TextBlock Text="RON" FontSize="16"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <NumberBox
                        x:Name="BidInputBox"
                        Header="Your bid (RON)"
                        Minimum="50"
                        Maximum="1000000"
                        Value="{x:Bind ViewModel.BidInput, Mode=TwoWay}"
                        SpinButtonPlacementMode="Inline"
                        Width="200"/>
                    <Button
                        Content="Bid"
                        VerticalAlignment="Bottom"
                        Click="PlaceBid_Click"/>
                </StackPanel>

                <TextBlock
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Foreground="Red"
                    Visibility="{x:Bind Vis(ViewModel.HasErrorMessage), Mode=OneWay}"/>

                <MenuFlyoutSeparator Margin="0,10,0,10"/>

                <TextBlock Text="Boost Your Profile" FontSize="24" FontWeight="Bold"/>
                <TextBlock
                    Text="Boost your profile for 25 RON and increase your compatibility score by 40 — until 23:59 today."
                    TextWrapping="Wrap"
                    FontSize="14"
                    Foreground="Gray"/>
                <Button
                    Content="🚀 Boost for 25 RON"
                    Click="BoostProfile_Click"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>